{
  "name": "bfc-script",
  "publisher": "Hallef Lima",
  "displayName": "bfc-Script syntax highlight",
  "icon": "icon/extension-icon.png",
  "description": "Suporte ao BFC Script com integração Groovy, sintax Highlight. Inclui alinhamento vertical automático para chamadas de métodos encadeadas e organização de blocos. Suporte a 'Format on Save'",
  "repository": {
    "type": "git",
    "url": "https://github.com/halleflima/bfc-script.git"
  },
  "version": "0.0.1",
  "main": "./src/extension.js",
  "engines": {
    "vscode": "^1.116.0"
  },
  "activationEvents": [
    "onLanguage:bfc"
  ],
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "iconThemes": [
      {
        "id": "bfc-icons",
        "label": "BFC Icons",
        "path": "./icon/bfc-icons.json"
      }
    ],
    "languages": [
      {
        "id": "bfc",
        "aliases": [
          "BFC Script",
          "bfc"
        ],
        "extensions": [
          ".bfc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bfc",
        "scopeName": "source.bfc",
        "path": "./syntaxes/bfc-script.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[bfc]": {
        "editor.defaultFormatter": "hallef.bfc",
        "editor.formatOnSave": true
      }
    }
  }
}