{
	"scopeName": "source.bfc",
	"name": "BFC Script",
	"fileTypes": [
		"bfc"
	],
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#namespaces"
		},
		{
			"include": "#groovy-methods"
		},
		{
			"include": "#method-chains"
		},
		{
			"include": "#function-calls"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#collections"
		},
		{
			"include": "#variables"
		}
	],
	"repository": {
		"collections": {
			"patterns": [
				{
					"name": "meta.structure.array.bfc",
					"begin": "\\[",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.array.begin.bfc"
						}
					},
					"end": "\\]",
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.array.end.bfc"
						}
					},
					"patterns": [
						{
							"include": "$self"
						},
						{
							"name": "punctuation.separator.array.bfc",
							"match": ","
						}
					]
				}
			]
		},
		"comments": {
			"patterns": [
				{
					"name": "comment.block.bfc",
					"begin": "/\\*",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.comment.bfc"
						}
					},
					"end": "\\*/",
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.comment.bfc"
						}
					}
				},
				{
					"name": "comment.line.bfc",
					"match": "(//).*$",
					"captures": {
						"1": {
							"name": "punctuation.definition.comment.bfc"
						}
					}
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.bfc",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"include": "#interpolation"
						},
						{
							"name": "constant.character.escape.bfc",
							"match": "\\\\."
						}
					]
				},
				{
					"name": "string.quoted.single.bfc",
					"begin": "'",
					"end": "'"
				}
			]
		},
		"interpolation": {
			"patterns": [
				{
					"name": "meta.interpolation.bfc",
					"begin": "\\$\\{",
					"end": "\\}",
					"patterns": [
						{
							"include": "#method-chains"
						},
						{
							"include": "#function-calls"
						},
						{
							"include": "#variables"
						},
						{
							"include": "#numbers"
						}
					]
				}
			]
		},
		"namespaces": {
			"patterns": [
				{
					"name": "support.class.bfc",
					"match": "\\b(Dados|Arquivo|Resultado|Datas)\\b"
				}
			]
		},
		"method-chains": {
			"patterns": [
				{
					"name": "meta.method.chain.bfc",
					"begin": "\\b(Dados|Arquivo|Resultado|Datas)",
					"end": "(?=\\s|\\)|;|$)",
					"patterns": [
						{
							"name": "support.class.bfc",
							"match": "\\b(Dados|Arquivo|Resultado|Datas)\\b"
						},
						{
							"name": "variable.other.property.bfc",
							"match": "\\.[a-zA-Z_][a-zA-Z0-9_]*"
						},
						{
							"name": "entity.name.function.bfc",
							"match": "\\.[a-zA-Z_][a-zA-Z0-9_]*(?=\\()"
						}
					]
				}
			]
		},
		"groovy-methods": {
			"patterns": [
				{
					"name": "support.function.bfc",
					"match": "\\.(each|collect|find|findAll|map)\\b"
				}
			]
		},
		"function-calls": {
			"patterns": [
				{
					"name": "meta.function-call.bfc",
					"match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
					"captures": {
						"1": {
							"name": "entity.name.function.bfc"
						}
					}
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "storage.type.function.bfc",
					"match": "\\bdef\\b"
				},
				{
					"name": "keyword.control.bfc",
					"match": "\\b(if|else|try|catch|return|each)\\b"
				},
				{
					"name": "keyword.control.custom.bfc",
					"match": "\\b(importar|imprimir|retornar)\\b"
				},
				{
					"name": "constant.language.bfc",
					"match": "\\b(true|false|null)\\b"
				},
				{
					"name": "constant.other.type.bfc",
					"match": "\\b(STRING|INTEGER|FLOAT|BOOLEAN)\\b"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.logical.bfc",
					"match": "&&|\\|\\||!"
				},
				{
					"name": "keyword.operator.comparison.bfc",
					"match": "==|!=|<=|>=|<|>"
				},
				{
					"name": "keyword.operator.assignment.bfc",
					"match": "="
				},
				{
					"name": "keyword.operator.arithmetic.bfc",
					"match": "\\+|\\-|\\*|\\/"
				},
				{
					"name": "keyword.operator.other.bfc",
					"match": "\\?|:|\\."
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.bfc",
					"match": "\\b\\d+(\\.\\d+)?\\b"
				}
			]
		},
		"variables": {
			"patterns": [
				{
					"name": "variable.other.bfc",
					"match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
				}
			]
		}
	}
}